# Optimized Linux kernel configuration for Phase 3
# Customized for performance and low-latency systems

# Real-time features
CONFIG_PREEMPT_RT=y
CONFIG_HZ_1000=y
CONFIG_RCU_NOCB_CPU=y

# CPU optimization
CONFIG_FUNCTION_TRACER=y
CONFIG_HAVE_FUNCTION_GRAPH_TRACER=y
CONFIG_SCHED_CORE=y

# Memory
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_THPCORE=y
CONFIG_HUGETLBFS=y
CONFIG_HUGETLB_PAGE=y

# Network
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_NETFILTER=y
CONFIG_IP_NF_IPTABLES=y

# Security
CONFIG_SMACK=y
CONFIG_AUDIT=y
CONFIG_SECURITY=y

# Module support
CONFIG_MODULES=y
CONFIG_MODVERSIONS=y

# Debugging (disabled for production)
# CONFIG_DEBUG_INFO is not set
CONFIG_DEBUG_SHIRQ=y
